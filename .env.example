# Workspace root for file/system tools.
CLAUDEPIPE_WORKSPACE=/Users/mg/workspace

# Session map persistence (conversation_key -> claude_session_id)
# Default: ~/.claude-pipe/sessions.json
# CLAUDEPIPE_SESSION_STORE_PATH=~/.claude-pipe/sessions.json

# Optional summary prompt templating for workspace-summary requests
CLAUDEPIPE_SUMMARY_PROMPT_ENABLED=true
CLAUDEPIPE_SUMMARY_PROMPT_TEMPLATE=Workspace: {{workspace}}\nRequest: {{request}}\nProvide a concise summary with key files and actionable insights.

# Optional transcript logging (off by default)
# Default: ~/.claude-pipe/transcript.jsonl
CLAUDEPIPE_TRANSCRIPT_LOG_ENABLED=false
# CLAUDEPIPE_TRANSCRIPT_LOG_PATH=~/.claude-pipe/transcript.jsonl
CLAUDEPIPE_TRANSCRIPT_LOG_MAX_BYTES=1000000
CLAUDEPIPE_TRANSCRIPT_LOG_MAX_FILES=3

# Tool configuration
CLAUDEPIPE_EXEC_TIMEOUT_SEC=60

# Discord channel
CLAUDEPIPE_DISCORD_ENABLED=false
CLAUDEPIPE_DISCORD_TOKEN=
CLAUDEPIPE_DISCORD_ALLOW_FROM=

# Optional: tuning
CLAUDEPIPE_MAX_TOOL_ITERATIONS=20
